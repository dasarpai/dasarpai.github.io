&lt;/figure>
&lt;/p>
&lt;h1 class="relative group">छान्दोग्योपनिषत् अष्टमोऽध्यायः
&lt;div id="%E0%A4%9B%E0%A4%A8%E0%A4%A6%E0%A4%97%E0%A4%AF%E0%A4%AA%E0%A4%A8%E0%A4%B7%E0%A4%A4--%E0%A4%85%E0%A4%B7%E0%A4%9F%E0%A4%AE%E0%A4%BD%E0%A4%A7%E0%A4%AF%E0%A4%AF" class="anchor">&lt;/div>
&lt;span
class="absolute top-0 w-6 transition-opacity opacity-0 ltr:-left-6 rtl:-right-6 not-prose group-hover:opacity-100">
&lt;a class="group-hover:text-primary-300 dark:group-hover:text-neutral-700"
